rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isGymOwner() {
      return isSignedIn() && (
        getUserRole(request.auth.uid) == 'owner'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation functions
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
          && data.email is string && data.email.size() <= 200
          && data.fullName is string && data.fullName.size() <= 200
          && data.role in ['client', 'owner']
          && data.joinedAt is string && data.joinedAt.size() <= 100;
    }

    function isValidClientProfile(data) {
      return (!('userId' in data) || (data.userId is string && data.userId.size() <= 128))
          && data.fullName is string && data.fullName.size() <= 200
          && data.isOnboarded is bool;
    }

    function isValidWorkout(data) {
      return data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.creatorId is string && data.creatorId.size() <= 128
          && data.date is string && data.date.size() <= 100
          && data.durationMinutes is number
          && data.caloriesBurned is number;
    }

    function isValidAnnouncement(data) {
      return data.id is string && data.id.size() <= 128
          && data.ownerId is string && data.ownerId.size() <= 128
          && data.title is string && data.title.size() <= 200
          && data.content is string && data.content.size() <= 2000
          && data.date is string && data.date.size() <= 100
          && data.urgency in ['normal', 'important', 'urgent'];
    }

    // Match patterns
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isGymOwner(); // Only owners can list all registered users
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'avatarUrl', 'role'])
      );
      allow delete: if false; // Users can't arbitrary delete their accounts
    }

    match /clientProfiles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isGymOwner());
      allow list: if isSignedIn() && isGymOwner(); // Only gym owners/admins can retrieve all profiles
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidClientProfile(incoming());
      allow update: if isSignedIn() && isValidId(userId) && (isOwner(userId) || isGymOwner()) && isValidClientProfile(incoming());
      allow delete: if false;
    }

    match /workouts/{workoutId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isGymOwner());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isGymOwner());
      allow create: if isSignedIn() && isValidId(workoutId) && (incoming().userId == request.auth.uid || isGymOwner()) && isValidWorkout(incoming());
      allow update: if isSignedIn() && isValidId(workoutId) && (existing().userId == request.auth.uid || isGymOwner()) && isValidWorkout(incoming());
      allow delete: if isSignedIn() && isValidId(workoutId) && (existing().userId == request.auth.uid || isGymOwner());
    }

    match /announcements/{announcementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(announcementId) && isGymOwner() && isValidAnnouncement(incoming());
      allow update: if isSignedIn() && isValidId(announcementId) && isGymOwner() && isValidAnnouncement(incoming());
      allow delete: if isSignedIn() && isValidId(announcementId) && isGymOwner();
    }
  }
}
